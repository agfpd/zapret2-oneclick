 		echo clearing $PKTWSD redirection
 		pktws_ipt_unprepare_tcp $2
@@ -1364,7 +1394,7 @@
 		mdig_resolve_all $IPV ips $3
 		pktws_ipt_prepare_udp $2 "$ips"
 
-		pktws_check_domain_http3_bypass $1 $3
