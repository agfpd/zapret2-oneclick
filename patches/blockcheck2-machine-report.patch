 			n=$(($n+1))
 			[ $REPEATS -gt 1 ] && printf "[attempt $n] "
 			if $1 "$IPV" "$2" $3 "$4" ; then
+				successes=$(($successes+1))
 				[ $REPEATS -gt 1 ] && echo 'AVAILABLE'
 			else
